Index,SS/Module,Test Case Name,Test Description,Speed,Mode,Memory Start Offset,Memory End Offset,Remarks,Test Steps/Procedure,Impacted Registers,Validation / Acceptance Criteria
1,NA,gpio_reg_wr_rd_test,"Validate default values and masked write/read behavior for addresses in addr_array using read_mask_array, write_mask_array and default_value_array; report mismatches in def_fail_cnt and wr_fail_cnt; call finish() based on counters.",NA,NA,0x00000000,0xFFFFFFFF,,"Call chk_rst_val(); for i from 0 to CNT-1: addr=addr_array[i]; if skip_rst_array[i]==1 continue; if read_mask_array[i]==0x00000000 continue; data_rd=read_reg(addr); data=(data_rd & 0xFFFFFFFE); compare to default_value_array[i]; on mismatch increment def_fail_cnt; then for each data_wr in [0xFFFFFFFF,0xAAAAAAAA,0x55555555,0xF5F5F5F5,0xA5A5A5A5,0xFFFF0000]: for i from 0 to CNT-1: if skip_array[i]==1 continue; if write_mask_array[i]==0x00000000 continue; write_reg(addr,(data_wr & write_mask_array[i])); then for i from 0 to CNT-1: if skip_array[i]==1 continue; if write_mask_array[i]==0x00000000 or read_mask_array[i]==0x00000000 continue; data_rd=(read_reg(addr) & read_mask_array[i]); wr_n=(write_mask_array[i] ^ 0xFFFFFFFF); exp_val=((data_wr & read_mask_array[i] & write_mask_array[i]) | (wr_n & read_mask_array[i] & default_value_array[i])); compare data_rd==exp_val; on mismatch increment wr_fail_cnt; finally if def_fail_cnt>0 or wr_fail_cnt>0 then finish(1) else finish(0).","MIZAR_GPIO_GP0_GPIO_8,MIZAR_GPIO_GP0_GPIO_9,MIZAR_GPIO_GP0_GPIO_10,MIZAR_GPIO_GP0_GPIO_11,MIZAR_GPIO_GP0_GPIO_12,MIZAR_GPIO_GP0_GPIO_13,MIZAR_GPIO_GP0_GPIO_14,MIZAR_GPIO_GP0_GPIO_15,MIZAR_GPIO_GP0_GPIO_16,MIZAR_GPIO_GP0_GPIO_17,MIZAR_GPIO_GP0_GPIO_18,MIZAR_GPIO_GP0_GPIO_19,MIZAR_GPIO_GP0_GPIO_20,MIZAR_GPIO_GP0_GPIO_21,MIZAR_GPIO_GP0_GPIO_22,MIZAR_GPIO_GP0_GPIO_23,MIZAR_GPIO_GP0_GPIO_24,MIZAR_GPIO_GP0_GPIO_25,MIZAR_GPIO_GP0_GPIO_26,MIZAR_GPIO_GP0_GPIO_27,MIZAR_GPIO_GP0_GPIO_28,MIZAR_GPIO_GP0_GPIO_29,MIZAR_GPIO_GP0_GPIO_30,MIZAR_GPIO_GP0_GPIO_31,MIZAR_GPIO_GP0_GPIO_32,MIZAR_GPIO_GP0_GPIO_33,MIZAR_GPIO_GP0_GPIO_34,MIZAR_GPIO_GP0_GPIO_35,MIZAR_GPIO_GP0_GPIO_36,MIZAR_GPIO_GP0_GPIO_37,MIZAR_GPIO_GP0_GPIO_38,MIZAR_GPIO_GP0_GPIO_39,MIZAR_GPIO_GPIO_INTR_RAW_STCLR1,MIZAR_GPIO_GP0_INTR1_INTR_EN1,MIZAR_GPIO_GP0_INTR1_INTR_STS1,MIZAR_GPIO_GP0_INTR2_INTR_EN1,MIZAR_GPIO_GP0_INTR2_INTR_STS1,MIZAR_GPIO_GPIO_IO_CTRL_GROUP1,MIZAR_GPIO_GPIO_IO_CTRL_GROUP2,MIZAR_GPIO_GPIO_IO_CTRL_GROUP3,MIZAR_GPIO_GPIO_IO_CTRL_GROUP4,MIZAR_GPIO_GPIO_DOUT_GROUP1,MIZAR_GPIO_GPIO_DOUT_GROUP2,MIZAR_GPIO_GPIO_DOUT_GROUP3,MIZAR_GPIO_GPIO_DOUT_GROUP4,MIZAR_GPIO_GPIO_DIN_GROUP1,MIZAR_GPIO_GPIO_DIN_GROUP2,MIZAR_GPIO_GPIO_DIN_GROUP3,MIZAR_GPIO_GPIO_DIN_GROUP4","All comparisons in chk_rst_val equal default_value_array[i] and in chk_rd_wr data_rd equals exp_val across all patterns and addresses; def_fail_cnt==0 and wr_fail_cnt==0 leading to finish(0); any mismatch increments counters and results in finish(1)."
2,NA,test_gpio_negedge_intr_en,"Configure per-pin registers at MIZAR_GPIO_GP0_GPIO_8+(i*4) with bits 20,18,16 set; enable MIZAR_LSS_SYSREG_INTR_EN1 and per-pin enables in MIZAR_GPIO_GP0_INTR1_INTR_EN1; drive 0xA0243FFC to generate edges and wait for Default_IRQHandler to clear MIZAR_GPIO_GPIO_INTR_RAW_STCLR1 and acknowledge MIZAR_LSS_SYSREG_RAW_STCR1.",NA,NA,0x00000000,0xFFFFFFFF,,"Initialize: optionally GIC_EnableIRQ(87/88); write MIZAR_LSS_SYSREG_INTR_EN1 with LSS_SYSREG_INTR_EN1_GPIOx_INTR under GPIO0/GPIO1; write 0xA0243FFC=0xFFFFFFFF; for i=0..31: write MIZAR_GPIO_GP0_GPIO_8+(i*4) with ((1u<<20)|(1u<<18)|(1u<<16)); then for each i: wr_val=(1u<<i); write MIZAR_GPIO_GPIO_INTR_RAW_STCLR1=wr_val; write MIZAR_GPIO_GP0_INTR1_INTR_EN1=wr_val; set int_pend=1; write 0xA0243FFC=0xFFFFFFFF; wait; write 0xA0243FFC=~wr_val; poll until int_pend==0 with timeout; finish(test_err). In Default_IRQHandler: set int_pend=0; read rdata from MIZAR_GPIO_GP0_GPIO_8+(i*4); if ((rdata & 0x1)!=0) increment test_err; if ((rdata & 0x2)!=0x0): read MIZAR_GPIO_GP0_INTR1_INTR_STS1; if ((rdata_grp & (1u<<i))==0) increment test_err; write MIZAR_GPIO_GP0_GPIO_8+(i*4) with ((1u<<20)|(1u<<16)); write MIZAR_GPIO_GPIO_INTR_RAW_STCLR1=(1u<<i); read MIZAR_GPIO_GP0_INTR1_INTR_STS1; if (rdata_grp!=0x0) increment test_err; acknowledge MIZAR_LSS_SYSREG_RAW_STCR1 and GIC_ClearIRQ(87/88) under GPIO0/GPIO1.","MIZAR_LSS_SYSREG_INTR_EN1,MIZAR_GPIO_GP0_GPIO_8,MIZAR_GPIO_GPIO_INTR_RAW_STCLR1,MIZAR_GPIO_GP0_INTR1_INTR_EN1,MIZAR_LSS_SYSREG_RAW_STCR1,MIZAR_GPIO_GP0_INTR1_INTR_STS1","No timeout in wait loop (interrupt observed); in Default_IRQHandler: (rdata & 0x1)==0; (rdata & 0x2)!=0; (read MIZAR_GPIO_GP0_INTR1_INTR_STS1 & (1u<<i)) != 0 before clearing; after write to MIZAR_GPIO_GPIO_INTR_RAW_STCLR1, MIZAR_GPIO_GP0_INTR1_INTR_STS1 reads 0x0; finish(test_err) reflects accumulated errors."
3,NA,test_gpio_pedge_all_pads_en,"Enable interrupts via MIZAR_LSS_SYSREG_INTR_EN1 and MIZAR_GPIO_GP0_INTR1_INTR_EN1; configure MIZAR_GPIO_GP0_GPIO_8+(i*4)=0x00020000 and set MIZAR_GPIO_GPIO_IO_CTRL_GROUP1..4; generate rising edges via 0xA0243FFC toggles; Default_IRQHandler validates group status, clears per-pin and system statuses, and re-enables MIZAR_GPIO_GP0_INTR1_INTR_EN1.",NA,NA,0x00000000,0xFFFFFFFF,,"Optionally GIC_EnableIRQ(87/88); write MIZAR_LSS_SYSREG_INTR_EN1 with LSS_SYSREG_INTR_EN1_GPIOx_INTR under GPIO0/GPIO1; for i=0..31: write MIZAR_GPIO_GP0_GPIO_8+(i*4)=0x00020000; wait; write MIZAR_GPIO_GPIO_IO_CTRL_GROUP1..4=0x000000FF; wait; write MIZAR_GPIO_GP0_INTR1_INTR_EN1=0xFFFFFFFF; for i=0..31: write 0xA0243FFC=0x00000000; wait; set int_pend=1; write 0xA0243FFC=0xFFFFFFFF; poll int_pend with timeout; on timeout print error and break; drive low again and continue; finish(test_err). In Default_IRQHandler: set int_pend=0; read MIZAR_GPIO_GP0_INTR1_INTR_STS1 to rdata_grp; mask group by writing MIZAR_GPIO_GP0_INTR1_INTR_EN1=0x00000000; if (rdata_grp & 0xFFFFFFFF)!=0 success else error; for j=0..31: write MIZAR_GPIO_GP0_GPIO_8+(j*4)=0x00010000; wait; read MIZAR_GPIO_GP0_INTR1_INTR_STS1; if rdata_grp==0x0 success else error; under GPIO0/GPIO1 write MIZAR_LSS_SYSREG_RAW_STCR1=LSS_SYSREG_RAW_STCR1_GPIOx_INTR then read MIZAR_LSS_SYSREG_RAW_STCR1 and if bit remains set increment test_err; re-enable MIZAR_GPIO_GP0_INTR1_INTR_EN1=0xFFFFFFFF and clear GIC IRQ.","MIZAR_LSS_SYSREG_INTR_EN1,MIZAR_GPIO_GP0_GPIO_8,MIZAR_GPIO_GPIO_IO_CTRL_GROUP1,MIZAR_GPIO_GPIO_IO_CTRL_GROUP2,MIZAR_GPIO_GPIO_IO_CTRL_GROUP3,MIZAR_GPIO_GPIO_IO_CTRL_GROUP4,MIZAR_GPIO_GP0_INTR1_INTR_EN1,MIZAR_GPIO_GP0_INTR1_INTR_STS1,MIZAR_LSS_SYSREG_RAW_STCR1","No timeout during polling (interrupt observed); in Default_IRQHandler: (MIZAR_GPIO_GP0_INTR1_INTR_STS1 & 0xFFFFFFFF) != 0 before clear; after clearing per-pin raw statuses and group, MIZAR_GPIO_GP0_INTR1_INTR_STS1 reads 0x0; MIZAR_LSS_SYSREG_RAW_STCR1 readback shows cleared bit; test_err remains 0 at finish."}]}